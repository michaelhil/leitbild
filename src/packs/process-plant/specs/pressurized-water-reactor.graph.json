{
  "schemaVersion": 1,
  "id": "process-plant.pressurized-water-reactor.v1",
  "title": "Pressurized Water Reactor",
  "timestep": {
    "fixedStepMs": 100
  },
  "components": [
    {
      "id": "core",
      "kind": "reactorCore",
      "label": "Reactor Core",
      "parameters": {
        "ratedPowerMw": 3400,
        "initialPowerFraction": 0.85
      }
    },
    {
      "id": "sgA",
      "kind": "steamGenerator",
      "label": "Steam Generator A",
      "parameters": {
        "nominalPressureMPa": 6.9,
        "nominalLevelPercent": 0.55,
        "heatTransferCoefficientMwPerK": 12
      }
    },
    {
      "id": "rcpA",
      "kind": "centrifugalPump",
      "label": "Reactor Coolant Pump A",
      "parameters": {
        "nominalFlowKgPerS": 4700,
        "nominalHeadPa": 650000
      }
    },
    {
      "id": "feedwaterA",
      "kind": "feedwaterSource",
      "label": "Feedwater Train A",
      "parameters": {
        "nominalFlowKgPerS": 760,
        "temperatureC": 220
      }
    },
    {
      "id": "turbine",
      "kind": "turbineLoadSink",
      "label": "Turbine Generator",
      "parameters": {
        "nominalElectricMw": 1100,
        "initialLoadFraction": 0.85
      }
    }
  ],
  "connections": [
    {
      "id": "rcs-hot-leg-a",
      "from": "core.hotLegA",
      "to": "sgA.primaryInlet",
      "medium": "primary-water"
    },
    {
      "id": "rcs-cold-leg-a",
      "from": "sgA.primaryOutlet",
      "to": "rcpA.inlet",
      "medium": "primary-water"
    },
    {
      "id": "rcp-a-to-core",
      "from": "rcpA.outlet",
      "to": "core.coldLegA",
      "medium": "primary-water"
    },
    {
      "id": "fw-a-to-sg-a",
      "from": "feedwaterA.outlet",
      "to": "sgA.feedwaterInlet",
      "medium": "feedwater"
    },
    {
      "id": "sg-a-steam-to-turbine",
      "from": "sgA.steamOutlet",
      "to": "turbine.steamInlet",
      "edgeKind": "steamFlow",
      "medium": "steam",
      "physical": {
        "lengthM": 38,
        "diameterM": 0.72,
        "volumeM3": 15.5,
        "nominalResistance": 0.08
      },
      "variables": [
        {
          "path": "flowKgPerS",
          "label": "Main steam flow",
          "kind": "derived",
          "domain": "hydraulic",
          "writable": false,
          "publish": "telemetry",
          "quantity": "flowRate",
          "unit": "kg/s",
          "initialValue": 0,
          "sensorId": "FT-SG-A-001"
        },
        {
          "path": "pressureMPa",
          "label": "Main steam pressure",
          "kind": "derived",
          "domain": "thermal",
          "writable": false,
          "publish": "telemetry",
          "quantity": "pressure",
          "unit": "MPa",
          "initialValue": 6.9,
          "sensorId": "PT-SG-A-001"
        },
        {
          "path": "radiationMSvPerH",
          "label": "Main steam radiation",
          "kind": "derived",
          "domain": "radiological",
          "writable": false,
          "publish": "telemetry",
          "quantity": "radiationDoseRate",
          "unit": "mSv/h",
          "initialValue": 0.02,
          "sensorId": "RT-SG-A-001"
        },
        {
          "path": "valve.positionFraction",
          "label": "Main steam isolation valve position",
          "kind": "control",
          "domain": "control",
          "writable": true,
          "publish": "telemetry",
          "quantity": "ratio",
          "unit": "fraction",
          "initialValue": 1,
          "actuatorId": "MSIV-A"
        },
        {
          "path": "leak.areaFraction",
          "label": "Main steam leak area",
          "kind": "control",
          "domain": "control",
          "writable": true,
          "publish": "telemetry",
          "quantity": "ratio",
          "unit": "fraction",
          "initialValue": 0
        }
      ]
    }
  ],
  "publishedVariables": [
    "core.powerMw",
    "sgA.levelPercent",
    "sgA.pressureMPa",
    "rcpA.running",
    "feedwaterA.flowKgPerS",
    "turbine.electricMw",
    "sg-a-steam-to-turbine.flowKgPerS",
    "sg-a-steam-to-turbine.pressureMPa",
    "sg-a-steam-to-turbine.radiationMSvPerH",
    "sg-a-steam-to-turbine.valve.positionFraction",
    "sg-a-steam-to-turbine.leak.areaFraction"
  ]
}
